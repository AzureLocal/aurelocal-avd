<mxfile host="draw.io" modified="2026-03-18T00:00:00.000Z" agent="GitHub Copilot" version="24.0.0" type="device">
  <diagram id="avd-identity" name="AVD on Azure Local — Identity &amp; RBAC Strategies">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;AVD on Azure Local — Identity &amp; RBAC (2 Supported Strategies)&lt;/b&gt;" style="text;html=1;fontSize=18;fontColor=#333;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="700" height="35" as="geometry"/>
        </mxCell>

        <!-- Azure Local constraint notice -->
        <mxCell id="notice" value="⚠️ &lt;b&gt;Entra-only join is NOT supported on Azure Local.&lt;/b&gt; Arc-enabled VMs (Microsoft.HybridCompute/machines) do not support Entra-only join. Only AD-Only and Hybrid Join are valid." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="200" y="50" width="700" height="35" as="geometry"/>
        </mxCell>

        <!-- ══════ USERS ══════ -->
        <mxCell id="user" value="&lt;b&gt;End User&lt;/b&gt;&lt;br&gt;AVD Client / Web" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="450" y="100" width="200" height="45" as="geometry"/>
        </mxCell>

        <!-- ══════ STRATEGY 1: AD-ONLY ══════ -->
        <mxCell id="s1-zone" value="&lt;b&gt;Strategy 1: AD-Only&lt;/b&gt;&lt;br&gt;&lt;i&gt;identity.strategy: ad_only&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=11;verticalAlign=top;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="20" y="170" width="500" height="380" as="geometry"/>
        </mxCell>

        <mxCell id="s1-flow" value="&lt;b&gt;Authentication Flow&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. User enters AD credentials in RD client&lt;br&gt;2. AVD Broker validates via Entra ID (client auth only)&lt;br&gt;3. Broker assigns session host&lt;br&gt;4. Session host authenticates user via&lt;br&gt;   Kerberos against on-premises Domain Controller&lt;br&gt;5. Domain join via JsonADDomainExtension&lt;br&gt;&lt;br&gt;&lt;b&gt;No SSO&lt;/b&gt; — user enters credentials at Windows logon" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="35" y="210" width="470" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="s1-dc" value="&lt;b&gt;Domain Controller&lt;/b&gt;&lt;br&gt;On-premises AD DS&lt;br&gt;DNS, Kerberos, LDAP&lt;br&gt;OU: OU=AVD,OU=Computers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E65100;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="35" y="350" width="200" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="s1-ext" value="&lt;b&gt;Extensions on Arc VM&lt;/b&gt;&lt;br&gt;├─ JsonADDomainExtension&lt;br&gt;│   (domain join + OU placement)&lt;br&gt;├─ AVD Agent Extension&lt;br&gt;│   (registers with host pool)&lt;br&gt;└─ Azure Monitor Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E65100;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="260" y="340" width="245" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="s1-rbac" value="&lt;b&gt;RBAC Required&lt;/b&gt;&lt;br&gt;├─ Desktop Virtualization User&lt;br&gt;│   → on Application Group&lt;br&gt;└─ (No VM Login roles needed — users auth directly to AD)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E65100;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="35" y="440" width="470" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="s1-note" value="&lt;b&gt;Pros:&lt;/b&gt; Simple, familiar, Kerberos for legacy apps, SOFS NTLM auth&lt;br&gt;&lt;b&gt;Cons:&lt;/b&gt; No SSO, no Conditional Access, requires on-prem DC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="35" y="505" width="470" height="35" as="geometry"/>
        </mxCell>

        <!-- ══════ STRATEGY 2: HYBRID JOIN (Recommended) ══════ -->
        <mxCell id="s2-zone" value="&lt;b&gt;Strategy 2: Hybrid Join (Recommended)&lt;/b&gt;&lt;br&gt;&lt;i&gt;identity.strategy: hybrid_join&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=11;verticalAlign=top;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="170" width="520" height="380" as="geometry"/>
        </mxCell>

        <mxCell id="s2-flow" value="&lt;b&gt;Authentication Flow&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. User authenticates to Entra ID (MFA / Conditional Access)&lt;br&gt;2. AVD Broker assigns session host via host pool&lt;br&gt;3. Session host is AD-joined + Entra-registered (hybrid)&lt;br&gt;4. Kerberos ticket from DC → on-prem resources + SOFS&lt;br&gt;5. PRT from Entra ID → cloud resources + M365 SSO&lt;br&gt;6. Azure AD Connect syncs identities bi-directionally&lt;br&gt;&lt;br&gt;&lt;b&gt;Full SSO + Conditional Access + on-prem access&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="575" y="210" width="490" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="s2-dc" value="&lt;b&gt;AD Domain Controller&lt;/b&gt;&lt;br&gt;Kerberos for on-prem + SOFS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7B1FA2;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="575" y="350" width="150" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="s2-entra" value="&lt;b&gt;Entra ID&lt;/b&gt;&lt;br&gt;MFA + Cond. Access" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7B1FA2;strokeColor=#4A148C;fontColor=#FFFFFF;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="745" y="350" width="140" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="s2-connect" value="&lt;b&gt;Azure AD Connect&lt;/b&gt;&lt;br&gt;Sync" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7B1FA2;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="905" y="350" width="120" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="s2-ext" value="&lt;b&gt;Extensions on Arc VM&lt;/b&gt;&lt;br&gt;├─ JsonADDomainExtension (domain join)&lt;br&gt;├─ &lt;b&gt;AADLoginForWindows&lt;/b&gt; (Entra hybrid SSO)&lt;br&gt;│   settings: { &quot;mdmId&quot;: &quot;&quot; }&lt;br&gt;├─ AVD Agent Extension&lt;br&gt;└─ Azure Monitor Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="575" y="410" width="490" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="s2-rbac" value="&lt;b&gt;RBAC Required&lt;/b&gt;&lt;br&gt;├─ Desktop Virtualization User → App Group&lt;br&gt;├─ Virtual Machine User Login → Resource Group&lt;br&gt;└─ Virtual Machine Administrator Login → RG (admins, optional)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="575" y="490" width="490" height="55" as="geometry"/>
        </mxCell>

        <!-- Connections -->
        <mxCell id="e-sync" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7B1FA2;strokeWidth=1;strokeDashPattern=4 4;" edge="1" parent="1" source="s2-dc" target="s2-connect">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-sync2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7B1FA2;strokeWidth=1;strokeDashPattern=4 4;" edge="1" parent="1" source="s2-connect" target="s2-entra">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-user1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" parent="1" source="user" target="s1-flow">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-user2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" parent="1" source="user" target="s2-flow">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
