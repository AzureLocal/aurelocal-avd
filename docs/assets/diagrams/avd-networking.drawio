<mxfile host="draw.io" modified="2026-03-18T00:00:00.000Z" agent="GitHub Copilot" version="24.0.0" type="device">
  <diagram id="avd-networking" name="AVD Networking — NSG Rules &amp; Private Endpoints">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;AVD Networking — NSG Rules, Private Endpoints &amp; DNS&lt;/b&gt;" style="text;html=1;fontSize=18;fontColor=#333;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="700" height="35" as="geometry"/>
        </mxCell>

        <!-- ══════ AZURE LOCAL VNET ══════ -->
        <mxCell id="vnet-zone" value="&lt;b&gt;Azure Local — Virtual Network / Logical Network&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=12;verticalAlign=top;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="680" height="520" as="geometry"/>
        </mxCell>

        <!-- Session Host Subnet -->
        <mxCell id="sh-subnet" value="&lt;b&gt;Session Host Subnet&lt;/b&gt;&lt;br&gt;10.0.1.0/24" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=11;verticalAlign=top;fontStyle=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="320" height="310" as="geometry"/>
        </mxCell>

        <!-- NSG -->
        <mxCell id="nsg" value="&lt;b&gt;NSG: hp-pool01-nsg&lt;/b&gt;&lt;br&gt;(attached to subnet)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="135" width="290" height="30" as="geometry"/>
        </mxCell>

        <!-- NSG Rules -->
        <mxCell id="rule1" value="&lt;b&gt;Priority 100: Allow-AVD-Service&lt;/b&gt;&lt;br&gt;Direction: Outbound&lt;br&gt;Source: VirtualNetwork&lt;br&gt;Dest: &lt;b&gt;WindowsVirtualDesktop&lt;/b&gt; (Service Tag)&lt;br&gt;Port: 443 (HTTPS)&lt;br&gt;Action: Allow&lt;br&gt;&lt;i&gt;Purpose: AVD Broker communication,&lt;br&gt;session orchestration, agent heartbeat&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C62828;fontSize=8;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="55" y="175" width="140" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="rule2" value="&lt;b&gt;Priority 110: Allow-AzureMonitor&lt;/b&gt;&lt;br&gt;Direction: Outbound&lt;br&gt;Source: VirtualNetwork&lt;br&gt;Dest: &lt;b&gt;AzureMonitor&lt;/b&gt; (Service Tag)&lt;br&gt;Port: 443 (HTTPS)&lt;br&gt;Action: Allow&lt;br&gt;&lt;i&gt;Purpose: Diagnostics, metrics,&lt;br&gt;AMA telemetry upload&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C62828;fontSize=8;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="205" y="175" width="140" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="rule3" value="&lt;b&gt;Priority 120: Allow-AzureAD&lt;/b&gt;&lt;br&gt;Direction: Outbound&lt;br&gt;Source: VirtualNetwork&lt;br&gt;Dest: &lt;b&gt;AzureActiveDirectory&lt;/b&gt;&lt;br&gt;Port: 443 (HTTPS)&lt;br&gt;Action: Allow&lt;br&gt;&lt;i&gt;Purpose: Entra ID auth,&lt;br&gt;Conditional Access, MFA&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C62828;fontSize=8;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="55" y="295" width="140" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="rule4" value="&lt;b&gt;Priority 130: Allow-KMS&lt;/b&gt;&lt;br&gt;Direction: Outbound&lt;br&gt;Source: VirtualNetwork&lt;br&gt;Dest: Internet&lt;br&gt;Port: 1688 (TCP)&lt;br&gt;Action: Allow&lt;br&gt;&lt;i&gt;Purpose: Windows activation&lt;br&gt;via Azure KMS server&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C62828;fontSize=8;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="205" y="295" width="140" height="100" as="geometry"/>
        </mxCell>

        <!-- Private Endpoint Subnet -->
        <mxCell id="pe-subnet" value="&lt;b&gt;Private Endpoint Subnet&lt;/b&gt;&lt;br&gt;10.0.2.0/24" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=11;verticalAlign=top;fontStyle=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="390" y="100" width="290" height="300" as="geometry"/>
        </mxCell>

        <!-- PE: Host Pool -->
        <mxCell id="pe-hp" value="&lt;b&gt;Private Endpoint: Host Pool&lt;/b&gt;&lt;br&gt;&lt;br&gt;pe-hp-pool01-connection&lt;br&gt;Sub-resource: &lt;b&gt;connection&lt;/b&gt;&lt;br&gt;Private IP: 10.0.2.4&lt;br&gt;&lt;br&gt;Keeps RDP reverse-connect&lt;br&gt;traffic on Microsoft backbone&lt;br&gt;(no public internet exposure)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#3F51B5;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="405" y="140" width="260" height="110" as="geometry"/>
        </mxCell>

        <!-- PE: Workspace -->
        <mxCell id="pe-ws" value="&lt;b&gt;Private Endpoint: Workspace&lt;/b&gt;&lt;br&gt;&lt;br&gt;pe-ws-avd-prod-feed&lt;br&gt;Sub-resource: &lt;b&gt;feed&lt;/b&gt;&lt;br&gt;Private IP: 10.0.2.5&lt;br&gt;&lt;br&gt;User feed discovery stays&lt;br&gt;on private network" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#3F51B5;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="405" y="265" width="260" height="100" as="geometry"/>
        </mxCell>

        <!-- Private DNS Zone -->
        <mxCell id="dns-zone" value="&lt;b&gt;Private DNS Zone&lt;/b&gt;&lt;br&gt;privatelink.wvd.microsoft.com" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="420" width="290" height="35" as="geometry"/>
        </mxCell>

        <!-- DNS records -->
        <mxCell id="dns-records" value="&lt;b&gt;DNS Records (auto-created by PE)&lt;/b&gt;&lt;br&gt;&lt;br&gt;hp-pool01.privatelink.wvd.microsoft.com → 10.0.2.4&lt;br&gt;ws-avd-prod.privatelink.wvd.microsoft.com → 10.0.2.5&lt;br&gt;&lt;br&gt;&lt;b&gt;On-premises DNS forwarding required:&lt;/b&gt;&lt;br&gt;*.wvd.microsoft.com → Azure Private DNS Resolver" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3F51B5;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="390" y="465" width="290" height="100" as="geometry"/>
        </mxCell>

        <!-- ══════ AZURE CLOUD ══════ -->
        <mxCell id="azure-zone" value="&lt;b&gt;Azure Cloud — AVD Service Endpoints&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#0078D4;fontSize=12;verticalAlign=top;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="770" y="60" width="580" height="250" as="geometry"/>
        </mxCell>

        <mxCell id="svc-wvd" value="&lt;b&gt;WindowsVirtualDesktop&lt;/b&gt;&lt;br&gt;Service Tag&lt;br&gt;&lt;br&gt;rdbroker.wvd.microsoft.com&lt;br&gt;rdweb.wvd.microsoft.com&lt;br&gt;rdgateway.wvd.microsoft.com&lt;br&gt;&lt;br&gt;Session brokering, gateway&lt;br&gt;reverse-connect, web client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#0078D4;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="790" y="100" width="170" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="svc-monitor" value="&lt;b&gt;AzureMonitor&lt;/b&gt;&lt;br&gt;Service Tag&lt;br&gt;&lt;br&gt;*.ods.opinsights.azure.com&lt;br&gt;*.oms.opinsights.azure.com&lt;br&gt;*.monitoring.azure.com&lt;br&gt;&lt;br&gt;LAW ingestion, AMA upload,&lt;br&gt;metrics pipeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#0078D4;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="980" y="100" width="170" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="svc-aad" value="&lt;b&gt;AzureActiveDirectory&lt;/b&gt;&lt;br&gt;Service Tag&lt;br&gt;&lt;br&gt;login.microsoftonline.com&lt;br&gt;login.windows.net&lt;br&gt;graph.microsoft.com&lt;br&gt;&lt;br&gt;Entra ID auth, token&lt;br&gt;issuance, CA policies" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#0078D4;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1170" y="100" width="160" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="svc-kms" value="&lt;b&gt;KMS Activation&lt;/b&gt;&lt;br&gt;azkms.core.windows.net:1688&lt;br&gt;kms.core.windows.net:1688" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#0078D4;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="790" y="235" width="260" height="40" as="geometry"/>
        </mxCell>

        <!-- ══════ DEPLOYMENT TOOLS ══════ -->
        <mxCell id="deploy-zone" value="&lt;b&gt;Deployment per IaC Tool&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=11;verticalAlign=top;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="770" y="340" width="580" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="d-tf" value="&lt;b&gt;Terraform (networking.tf)&lt;/b&gt;&lt;br&gt;&lt;br&gt;azurerm_network_security_group&lt;br&gt;+ 4 dynamic security_rule blocks&lt;br&gt;azurerm_private_endpoint × 2&lt;br&gt;+ dns_zone_group for auto DNS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="785" y="370" width="170" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="d-bicep" value="&lt;b&gt;Bicep (networking.bicep)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Microsoft.Network/nsg@2023-09-01&lt;br&gt;Microsoft.Network/privateEndpoints&lt;br&gt;privateDnsZoneGroups child resource&lt;br&gt;→ ARM: networking.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="970" y="370" width="175" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="d-ps" value="&lt;b&gt;PowerShell&lt;/b&gt;&lt;br&gt;Configure-AVDNetworking.ps1&lt;br&gt;&lt;br&gt;New-AzNetworkSecurityGroup&lt;br&gt;New-AzPrivateEndpoint&lt;br&gt;New-AzPrivateDnsZone" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="785" y="475" width="170" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="d-ansible" value="&lt;b&gt;Ansible (avd-networking role)&lt;/b&gt;&lt;br&gt;&lt;br&gt;azure_rm_securitygroup&lt;br&gt;azure_rm_resource (PE)&lt;br&gt;+ Private DNS zone groups" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="970" y="475" width="175" height="80" as="geometry"/>
        </mxCell>

        <!-- ══════ CONNECTIONS ══════ -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=2;" edge="1" parent="1" source="rule1" target="svc-wvd">
          <mxGeometry relative="1" as="geometry"/>
