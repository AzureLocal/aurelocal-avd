<mxfile host="app.diagrams.net" modified="2026-03-22T00:00:00.000Z" agent="Copilot" version="24.7.17" type="device">
	<diagram id="avd-fslogix-profile-selection" name="FSLogix Profile Container Model Selection">
		<mxGraphModel dx="1100" dy="740" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="530" math="0" shadow="0">
			<root>
				<mxCell id="0"/>
				<mxCell id="1" parent="0"/>

				<!-- Title -->
				<mxCell id="title" value="&lt;b&gt;FSLogix Profile Container Model Selection&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#222222;" vertex="1" parent="1">
					<mxGeometry x="60" y="12" width="1080" height="30" as="geometry"/>
				</mxCell>

				<!-- Question bar -->
				<mxCell id="q1" value="&lt;b&gt;Which best describes your environment?&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=12;fontStyle=1;fontColor=#222222" vertex="1" parent="1">
					<mxGeometry x="60" y="52" width="1080" height="36" as="geometry"/>
				</mxCell>

				<!-- Left panel: VHDX on SOFS (Recommended) -->
				<mxCell id="sofs_panel" value="&lt;b&gt;VHDX on SOFS&lt;/b&gt;&lt;br&gt;&lt;br&gt;Azure Local with AD DS / Hybrid Entra ID&lt;br&gt;Low-latency on-premises SMB (under 5 ms)&lt;br&gt;No multi-site DR for profiles required&lt;br&gt;Simple operational model preferred&lt;br&gt;&lt;br&gt;────────────────────────────────────────&lt;br&gt;&lt;br&gt;&lt;b&gt;Registry key:&lt;/b&gt; VHDLocations&lt;br&gt;&lt;b&gt;Auth:&lt;/b&gt; Kerberos (AD DS or Hybrid)&lt;br&gt;&lt;b&gt;Cloud dependency:&lt;/b&gt; None in steady state&lt;br&gt;&lt;b&gt;Write overhead:&lt;/b&gt; 1× (direct write to VHDX)&lt;br&gt;&lt;b&gt;Ops complexity:&lt;/b&gt; Low" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;verticalAlign=top;spacingTop=12;spacingLeft=12;spacingRight=12;align=left;strokeWidth=2" vertex="1" parent="1">
					<mxGeometry x="60" y="108" width="520" height="298" as="geometry"/>
				</mxCell>

				<!-- Recommended badge -->
				<mxCell id="rec" value="★  Recommended for Azure Local" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e7d32;strokeColor=#1b5e20;fontStyle=1;fontSize=11;fontColor=#ffffff" vertex="1" parent="1">
					<mxGeometry x="80" y="420" width="300" height="30" as="geometry"/>
				</mxCell>

				<!-- Right panel: Cloud Cache CCD -->
				<mxCell id="ccd_panel" value="&lt;b&gt;Cloud Cache (CCD)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Multi-site active-active DR required&lt;br&gt;Entra-only environment (no on-prem AD DS)&lt;br&gt;Multiple simultaneous storage backends needed&lt;br&gt;Azure Files or Blob Storage available&lt;br&gt;&lt;br&gt;────────────────────────────────────────&lt;br&gt;&lt;br&gt;&lt;b&gt;Registry key:&lt;/b&gt; CCDLocations&lt;br&gt;&lt;b&gt;Auth:&lt;/b&gt; Entra Kerberos or storage key&lt;br&gt;&lt;b&gt;Cloud dependency:&lt;/b&gt; Azure Files or Blob&lt;br&gt;&lt;b&gt;Write overhead:&lt;/b&gt; 2–3× (all providers)&lt;br&gt;&lt;b&gt;Ops complexity:&lt;/b&gt; High" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=top;spacingTop=12;spacingLeft=12;spacingRight=12;align=left;strokeWidth=2" vertex="1" parent="1">
					<mxGeometry x="620" y="108" width="520" height="298" as="geometry"/>
				</mxCell>

				<!-- Arrows from question to panels -->
				<mxCell id="aq_left" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#82b366;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="q1" target="sofs_panel">
					<mxGeometry relative="1" as="geometry"/>
				</mxCell>
				<mxCell id="aq_right" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#6c8ebf;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="q1" target="ccd_panel">
					<mxGeometry relative="1" as="geometry"/>
				</mxCell>

				<!-- Bottom note -->
				<mxCell id="note" value="Do not mix models within a single host pool. Introduce Cloud Cache only when AD DS is unavailable or explicit multi-site DR is required." style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555555" vertex="1" parent="1">
					<mxGeometry x="60" y="470" width="1080" height="30" as="geometry"/>
				</mxCell>
			</root>
		</mxGraphModel>
	</diagram>
</mxfile>
