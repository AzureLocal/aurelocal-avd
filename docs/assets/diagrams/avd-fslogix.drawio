<mxfile host="draw.io" modified="2026-03-18T00:00:00.000Z" agent="GitHub Copilot" version="24.0.0" type="device">
  <diagram id="avd-fslogix" name="FSLogix Profile Containers — Architecture">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;FSLogix Profile Containers — 3 Topology Options&lt;/b&gt;" style="text;html=1;fontSize=18;fontColor=#333;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="700" height="35" as="geometry"/>
        </mxCell>

        <!-- ══════ SESSION HOSTS ══════ -->
        <mxCell id="sh-zone" value="&lt;b&gt;Session Hosts (Azure Local Arc VMs)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=12;verticalAlign=top;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="330" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="sh1" value="&lt;b&gt;sh-pool01-001&lt;/b&gt;&lt;br&gt;FSLogix Agent installed&lt;br&gt;&lt;br&gt;Registry keys set via:&lt;br&gt;• Arc CustomScriptExtension&lt;br&gt;  (Terraform azapi_resource)&lt;br&gt;• Configure-FSLogix.ps1&lt;br&gt;• Ansible avd-fslogix role&lt;br&gt;&lt;br&gt;HKLM:\\SOFTWARE\\FSLogix\\Profiles&lt;br&gt;├─ Enabled = 1&lt;br&gt;├─ VHDLocations = \\\\share\\path&lt;br&gt;├─ SizeInMBs = 30720&lt;br&gt;├─ IsDynamic = 1&lt;br&gt;├─ VolumeType = VHDX&lt;br&gt;└─ FlipFlopProfileDirectoryName = 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E65100;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="35" y="95" width="300" height="250" as="geometry"/>
        </mxCell>

        <!-- ══════ TOPOLOGY 1: SINGLE ══════ -->
        <mxCell id="t1-zone" value="&lt;b&gt;Topology 1: Single Share&lt;/b&gt;&lt;br&gt;&lt;i&gt;share_topology: single&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;verticalAlign=top;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="420" y="60" width="300" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="t1-share" value="&lt;b&gt;\\\\fs-01\\FSLogix\\Profiles&lt;/b&gt;&lt;br&gt;SMB 3.x File Share&lt;br&gt;&lt;br&gt;Per-user VHDx:&lt;br&gt;├─ john.doe_SID/&lt;br&gt;│   └─ Profile_john.doe.VHDX&lt;br&gt;│       ├─ AppData\\&lt;br&gt;│       ├─ Desktop\\&lt;br&gt;│       ├─ Documents\\&lt;br&gt;│       └─ ODFC (Office cache)&lt;br&gt;├─ jane.doe_SID/&lt;br&gt;│   └─ Profile_jane.doe.VHDX&lt;br&gt;└─ ..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="435" y="95" width="270" height="170" as="geometry"/>
        </mxCell>

        <!-- ══════ TOPOLOGY 2: SPLIT ══════ -->
        <mxCell id="t2-zone" value="&lt;b&gt;Topology 2: Split (Profile + Office)&lt;/b&gt;&lt;br&gt;&lt;i&gt;share_topology: split&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#0078D4;fontSize=11;verticalAlign=top;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="420" y="310" width="300" height="270" as="geometry"/>
        </mxCell>
        <mxCell id="t2-profile" value="&lt;b&gt;Profile Share&lt;/b&gt;&lt;br&gt;\\\\fs-01\\FSLogix\\Profiles&lt;br&gt;&lt;br&gt;VHDx contains:&lt;br&gt;├─ AppData\\&lt;br&gt;├─ Desktop\\&lt;br&gt;├─ Documents\\&lt;br&gt;└─ Registry hive&lt;br&gt;&lt;br&gt;&lt;i&gt;Typically smaller (5-15 GB)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#0078D4;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="435" y="350" width="270" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="t2-odfc" value="&lt;b&gt;Office Container (ODFC)&lt;/b&gt;&lt;br&gt;\\\\fs-01\\FSLogix\\ODFC&lt;br&gt;&lt;br&gt;VHDx contains:&lt;br&gt;├─ Outlook OST cache&lt;br&gt;├─ OneDrive cache&lt;br&gt;├─ Teams cache&lt;br&gt;└─ Search index&lt;br&gt;&lt;br&gt;&lt;i&gt;Can grow large (15-30 GB)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#0078D4;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="435" y="460" width="270" height="105" as="geometry"/>
        </mxCell>

        <!-- ══════ TOPOLOGY 3: CLOUD CACHE ══════ -->
        <mxCell id="t3-zone" value="&lt;b&gt;Topology 3: Cloud Cache (HA / DR)&lt;/b&gt;&lt;br&gt;&lt;i&gt;share_topology: cloud_cache&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=11;verticalAlign=top;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="780" y="60" width="350" height="510" as="geometry"/>
        </mxCell>
        <mxCell id="t3-local" value="&lt;b&gt;Local Cache (on Session Host)&lt;/b&gt;&lt;br&gt;C:\\ProgramData\\FSLogix\\Cache\\&lt;br&gt;&lt;br&gt;VHDx mounted from local cache&lt;br&gt;Write-back to all providers&lt;br&gt;Instant logon (no SMB wait)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="800" y="105" width="310" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="t3-primary" value="&lt;b&gt;Provider 1 — Primary Site&lt;/b&gt;&lt;br&gt;type=smb,connectionString=&lt;br&gt;\\\\primary.domain.local\\FSLogix&lt;br&gt;&lt;br&gt;Synchronous write-back&lt;br&gt;Closest to session hosts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="800" y="210" width="310" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="t3-secondary" value="&lt;b&gt;Provider 2 — DR Site&lt;/b&gt;&lt;br&gt;type=smb,connectionString=&lt;br&gt;\\\\secondary.domain.local\\FSLogix&lt;br&gt;&lt;br&gt;Asynchronous replication&lt;br&gt;Failover target" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="800" y="310" width="310" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="t3-azure" value="&lt;b&gt;Provider 3 — Azure Files (Optional)&lt;/b&gt;&lt;br&gt;type=azure,connectionString=&lt;br&gt;stfslogixprod.file.core.windows.net&lt;br&gt;&lt;br&gt;Cloud backup / tertiary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=9;strokeDashPattern=8 8;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="800" y="410" width="310" height="70" as="geometry"/>
        </mxCell>

        <!-- ══════ NTFS PERMISSIONS ══════ -->
        <mxCell id="ntfs-zone" value="&lt;b&gt;NTFS Permission Model (All Shares)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;verticalAlign=top;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="20" y="400" width="330" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="ntfs-detail" value="&lt;b&gt;Share-Level (SMB)&lt;/b&gt;&lt;br&gt;  AVD Users → Change&lt;br&gt;  Administrators → Full Control&lt;br&gt;&lt;br&gt;&lt;b&gt;Folder-Level (NTFS)&lt;/b&gt;&lt;br&gt;  CREATOR OWNER → Full Control (subfolders+files)&lt;br&gt;  AVD Users → Modify (this folder only)&lt;br&gt;  BUILTIN\\Administrators → Full Control (all)&lt;br&gt;&lt;br&gt;&lt;i&gt;Provisioned by New-FSLogixShare.ps1&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C62828;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="35" y="425" width="300" height="135" as="geometry"/>
        </mxCell>

        <!-- ══════ CONNECTIONS ══════ -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" parent="1" source="sh1" target="t1-share">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e1l" value="SMB 3.x" style="edgeLabel;html=1;fontSize=8;" vertex="1" connectable="0" parent="e1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#0078D4;strokeWidth=2;" edge="1" parent="1" source="sh1" target="t2-profile">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7B1FA2;strokeWidth=2;" edge="1" parent="1" source="sh1" target="t3-local">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7B1FA2;strokeWidth=1;strokeDashPattern=4 4;" edge="1" parent="1" source="t3-local" target="t3-primary">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4l" value="sync write" style="edgeLabel;html=1;fontSize=8;" vertex="1" connectable="0" parent="e4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7B1FA2;strokeWidth=1;strokeDashPattern=4 4;" edge="1" parent="1" source="t3-local" target="t3-secondary">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5l" value="async replica" style="edgeLabel;html=1;fontSize=8;" vertex="1" connectable="0" parent="e5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
