{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "appGroupName": { "type": "string" },
    "desktopVirtualizationUserGroupId": { "type": "string" },
    "vmUserLoginGroupId": { "type": "string" },
    "vmAdminLoginGroupId": { "type": "string" },
    "sessionHostResourceGroupName": { "type": "string" }
  },
  "variables": {
    "desktopVirtualizationUserRole": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '1d336d6b-1444-4a47-9fbb-26e0a0e4f6bb')]",
    "vmUserLoginRole": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'fb879df8-f326-4884-b1cf-06f3ad86be52')]",
    "vmAdminLoginRole": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '1c0163c0-47e6-4577-8991-ea5c82e286e4')]"
  },
  "resources": [
    {
      "condition": "[not(empty(parameters('desktopVirtualizationUserGroupId')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceId('Microsoft.DesktopVirtualization/applicationGroups', parameters('appGroupName')), parameters('desktopVirtualizationUserGroupId'), variables('desktopVirtualizationUserRole'))]",
      "scope": "[resourceId('Microsoft.DesktopVirtualization/applicationGroups', parameters('appGroupName'))]",
      "properties": {
        "roleDefinitionId": "[variables('desktopVirtualizationUserRole')]",
        "principalId": "[parameters('desktopVirtualizationUserGroupId')]",
        "principalType": "Group"
      }
    }
  ]
}
