    "peakStartMinute": {
      "type": "int",
      "defaultValue": 0,
      "metadata": {
        "description": "Peak start time (minute)"
      }
    },
    "peakLBAlgorithm": {
      "type": "string",
      "defaultValue": "BreadthFirst",
      "allowedValues": [
        "BreadthFirst",
        "DepthFirst"
      ],
      "metadata": {
        "description": "Peak load balancing algorithm"
      }
    },
    "rampDownStartHour": {
      "type": "int",
      "defaultValue": 17,
      "metadata": {
