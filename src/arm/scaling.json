      }
    },
    "rampUpStartMinute": {
      "type": "int",
      "defaultValue": 0,
      "metadata": {
        "description": "Ramp-up start time (minute)"
      }
    },
    "rampUpLBAlgorithm": {
      "type": "string",
      "defaultValue": "BreadthFirst",
      "allowedValues": [
