    },
    "rampDownCapacityPct": {
      "type": "int",
      "defaultValue": 90,
      "metadata": {
        "description": "Ramp-down capacity threshold percent"
      }
    },
    "rampDownForceLogoff": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Force logoff users during ramp-down"
      }
    },
    "rampDownWaitMinutes": {
      "type": "int",
      "defaultValue": 30,
      "metadata": {
        "description": "Wait time before force logoff (minutes)"
      }
    },
    "rampDownNotification": {
      "type": "string",
      "defaultValue": "Your session will be logged off in 30 minutes.",
      "metadata": {
        "description": "Notification message before forced logoff"
