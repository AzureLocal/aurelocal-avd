      "metadata": {
        "description": "Off-peak load balancing algorithm"
      }
    }
  },
  "resources": [
    {
      "condition": "[and(parameters('scalingEnabled'), equals(parameters('hostPoolType'), 'Pooled'))]",
      "type": "Microsoft.DesktopVirtualization/scalingPlans",
      "apiVersion": "2024-04-03",
      "name": "[parameters('scalingPlanName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "timeZone": "[parameters('timeZone')]",
        "friendlyName": "[format('{0} Scaling Plan', parameters('scalingPlanName'))]",
        "hostPoolType": "Pooled",
        "hostPoolReferences": [
          {
            "hostPoolArmPath": "[parameters('hostPoolId')]",
            "scalingPlanEnabled": true
          }
        ],
        "schedules": [
          {
            "name": "[parameters('scheduleName')]",
            "daysOfWeek": "[parameters('scheduleDays')]",
            "rampUpStartTime": {
              "hour": "[parameters('rampUpStartHour')]",
              "minute": "[parameters('rampUpStartMinute')]"
            },
            "rampUpLoadBalancingAlgorithm": "[parameters('rampUpLBAlgorithm')]",
            "rampUpMinimumHostsPct": "[parameters('rampUpMinHostsPct')]",
            "rampUpCapacityThresholdPct": "[parameters('rampUpCapacityPct')]",
            "peakStartTime": {
              "hour": "[parameters('peakStartHour')]",
              "minute": "[parameters('peakStartMinute')]"
            },
            "peakLoadBalancingAlgorithm": "[parameters('peakLBAlgorithm')]",
            "rampDownStartTime": {
              "hour": "[parameters('rampDownStartHour')]",
              "minute": "[parameters('rampDownStartMinute')]"
            },
            "rampDownLoadBalancingAlgorithm": "[parameters('rampDownLBAlgorithm')]",
            "rampDownMinimumHostsPct": "[parameters('rampDownMinHostsPct')]",
            "rampDownCapacityThresholdPct": "[parameters('rampDownCapacityPct')]",
            "rampDownForceLogoffUsers": "[parameters('rampDownForceLogoff')]",
            "rampDownWaitTimeMinutes": "[parameters('rampDownWaitMinutes')]",
            "rampDownNotificationMessage": "[parameters('rampDownNotification')]",
            "offPeakStartTime": {
              "hour": "[parameters('offPeakStartHour')]",
              "minute": "[parameters('offPeakStartMinute')]"
            },
            "offPeakLoadBalancingAlgorithm": "[parameters('offPeakLBAlgorithm')]"
          }
        ]
      }
    }
  ],
  "outputs": {
    "scalingPlanId": {
      "type": "string",
      "value": "[if(and(parameters('scalingEnabled'), equals(parameters('hostPoolType'), 'Pooled')), resourceId('Microsoft.DesktopVirtualization/scalingPlans', parameters('scalingPlanName')), '')]"
    },
    "scalingPlanName": {
      "type": "string",
      "value": "[if(and(parameters('scalingEnabled'), equals(parameters('hostPoolType'), 'Pooled')), parameters('scalingPlanName'), '')]"
    }
  }
