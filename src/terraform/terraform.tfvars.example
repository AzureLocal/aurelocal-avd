# Copy to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars (it is .gitignore'd).

# ── Control Plane ─────────────────────────────────────────────────────────────

location                     = "eastus"
resource_group_name          = "rg-avd-prod"
host_pool_name               = "hp-azurelocal-pool01"
host_pool_type               = "Pooled"
load_balancer_type           = "BreadthFirst"
max_session_limit            = 10
app_group_name               = "ag-avd-desktops"
workspace_name               = "ws-avd-prod"
key_vault_name               = "kv-avd-prod-001"
log_analytics_workspace_name = "law-avd-prod"
log_analytics_retention_days = 30

# ── Session Hosts ─────────────────────────────────────────────────────────────

custom_location_id = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-azurelocal/providers/Microsoft.ExtendedLocation/customLocations/cl-azurelocal-01"

vm_name_prefix = "avd-sh"
vm_count       = 2
vm_size        = "Standard_D4s_v3"

image_id = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-azurelocal/providers/Microsoft.AzureStackHCI/galleryImages/win11-multisession-23h2"
storage_path_id = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-azurelocal/providers/Microsoft.AzureStackHCI/storageContainers/sp-vmstore-01"

vnet_id     = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-azurelocal/providers/Microsoft.AzureStackHCI/virtualNetworks/vnet-azurelocal-01"
subnet_name = "default"

domain_fqdn      = "iic.local"
domain_join_user = "svc-domainjoin@iic.local"
ou_path          = "OU=AVD,OU=Computers,DC=iic,DC=local"

# ── RBAC ──────────────────────────────────────────────────────────────────────

desktop_virtualization_user_group_id = "00000000-0000-0000-0000-000000000000"
vm_user_login_group_id               = "00000000-0000-0000-0000-000000000000"
vm_admin_login_group_id              = "00000000-0000-0000-0000-000000000000"
start_vm_on_connect_principal_id     = "00000000-0000-0000-0000-000000000000"

# ── FSLogix ───────────────────────────────────────────────────────────────────

fslogix_enabled            = true
fslogix_profile_share_path = "\\\\sofs-cluster\\FSLogixProfiles"
fslogix_size_in_mbs        = 30720

# ── Tags ──────────────────────────────────────────────────────────────────────

environment_tag = "production"
owner_tag       = "platform-team"
