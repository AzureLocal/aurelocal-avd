// =============================================================================
// AVD Control Plane — Example Parameters File
// =============================================================================
// EXAMPLE ONLY — DO NOT USE DIRECTLY
//
// The deploy script (deploy/Deploy-AVDSessionHosts.ps1) builds a
// -TemplateParameterObject at runtime from config/variables.yml.
// This file exists for documentation and manual testing only.
// =============================================================================

using './main.bicep'

// --- Resource Group ---
param resourceGroupName = '<RESOURCE_GROUP_NAME>'
param location = '<AZURE_REGION>'

// --- Host Pool ---
param hostPoolName = '<HOST_POOL_NAME>'
param hostPoolType = 'Pooled'
param loadBalancerType = 'BreadthFirst'
param maxSessionLimit = 16
param preferredAppGroupType = 'Desktop'
param personalDesktopAssignmentType = 'Automatic'
param startVMOnConnect = false
param validationEnvironment = false
param customRdpProperty = ''
param hostPoolFriendlyName = ''
param hostPoolDescription = ''

// --- Application Group ---
param appGroupName = '<APP_GROUP_NAME>'
param appGroupType = 'Desktop'
param appGroupFriendlyName = ''

// --- Workspace ---
param workspaceName = '<WORKSPACE_NAME>'
param workspaceFriendlyName = ''

// --- Tags ---
param tags = {}

// --- Entra ID Authentication ---
param enableEntraIdAuth = true
