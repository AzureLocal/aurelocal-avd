name: Deploy AVD Session Hosts

on:
  workflow_dispatch:
    inputs:
      resource_group_name:
        description: 'Resource group name'
        required: true
        default: 'rg-avd-prod'
      vm_count:
        description: 'Number of session hosts to deploy'
        required: true
        default: '2'

permissions:
  id-token: write
  contents: read

env:
  BICEP_FILE: src/bicep/session-hosts.bicep
  BICEP_PARAMS: src/bicep/session-hosts.bicepparam

jobs:
  validate:
    name: Validate Bicep
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Azure Login (OIDC)
        uses: azure/login@v2
        with:
          client-id: ${{ secrets.AZURE_CLIENT_ID }}
          tenant-id: ${{ secrets.AZURE_TENANT_ID }}
          subscription-id: ${{ secrets.AZURE_SUBSCRIPTION_ID }}

      - name: Install Bicep CLI
        run: az bicep install

      - name: Bicep Build (lint)
        run: az bicep build --file ${{ env.BICEP_FILE }}

      - name: What-if deployment
        run: |
          az deployment sub what-if \
            --location eastus \
            --template-file ${{ env.BICEP_FILE }} \
            --parameters ${{ env.BICEP_PARAMS }} \
            --parameters sessionHostCount=${{ github.event.inputs.vm_count }}

  deploy:
    name: Deploy Session Hosts
    runs-on: ubuntu-latest
    needs: validate
    environment: production
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Azure Login (OIDC)
        uses: azure/login@v2
        with:
          client-id: ${{ secrets.AZURE_CLIENT_ID }}
          tenant-id: ${{ secrets.AZURE_TENANT_ID }}
          subscription-id: ${{ secrets.AZURE_SUBSCRIPTION_ID }}

      - name: Install Bicep CLI
        run: az bicep install

      - name: Deploy Session Hosts
        run: |
          az deployment sub create \
            --name "avd-session-hosts-$(date +%Y%m%d%H%M%S)" \
            --location eastus \
            --template-file ${{ env.BICEP_FILE }} \
            --parameters ${{ env.BICEP_PARAMS }} \
            --parameters sessionHostCount=${{ github.event.inputs.vm_count }}

      - name: Verify session hosts
        run: |
          echo "Waiting 120s for AVD agent registration..."
          sleep 120
          echo "Session hosts deployment submitted successfully."
          echo "Verify in Azure Portal: AVD > Host Pools > Session Hosts"
